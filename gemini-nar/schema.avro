{
  "type": "record",
  "name": "UserObject",
  "namespace": "com.gemini.avro",
  "fields": [
    {
      "name": "id",
      "type": "string"
    },
    {
      "name": "username",
      "type": "string"
    },
    {
      "name": "email",
      "type": "string"
    },
    {
      "name": "isActive",
      "type": "boolean"
    },
    {
      "name": "profile",
      "type": {
        "type": "record",
        "name": "UserProfile",
        "fields": [
          {
            "name": "firstName",
            "type": "string"
          },
          {
            "name": "lastName",
            "type": "string"
          },
          {
            "name": "avatar",
            "type": "string"
          },
          {
            "name": "bio",
            "type": "string"
          },
          {
            "name": "skills",
            "type": {
              "type": "array",
              "items": "string"
            }
          }
        ]
      }
    },
    {
      "name": "preferences",
      "type": {
        "type": "record",
        "name": "UserPreferences",
        "fields": [
          {
            "name": "theme",
            "type": "string"
          },
          {
            "name": "notifications",
            "type": {
              "type": "record",
              "name": "NotificationSettings",
              "fields": [
                {
                  "name": "email",
                  "type": "boolean"
                },
                {
                  "name": "push",
                  "type": "boolean"
                },
                {
                  "name": "slack",
                  "type": "boolean"
                }
              ]
            }
          },
          {
            "name": "fontSize",
            "type": "int"
          },
          {
            "name": "dashboardLayout",
            "type": {
              "type": "array",
              "items": "string"
            }
          }
        ]
      }
    },
    {
      "name": "systemTelemetry",
      "type": {
        "type": "record",
        "name": "SystemTelemetry",
        "fields": [
          {
            "name": "cpuUsagePercent",
            "type": "double"
          },
          {
            "name": "memoryUsageBytes",
            "type": "long"
          },
          {
            "name": "diskStatus",
            "type": "string"
          },
          {
            "name": "uptimeSeconds",
            "type": "long"
          },
          {
            "name": "lastPing",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "tags",
      "type": {
        "type": "array",
        "items": "string"
      }
    },
    {
      "name": "meta",
      "type": {
        "type": "record",
        "name": "Metadata",
        "fields": [
          {
            "name": "version",
            "type": "string"
          },
          {
            "name": "environment",
            "type": "string"
          },
          {
            "name": "generatedBy",
            "type": "string"
          },
          {
            "name": "seedValue",
            "type": "long"
          }
        ]
      }
    }
  ]
}
